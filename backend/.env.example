# Copy this to .env and fill in values
# Local development:
DATABASE_URL=postgresql://postgres:password@localhost:5432/recipes_db
ANTHROPIC_API_KEY=sk-ant-...

# Production (Render sets this automatically when you attach a Postgres DB)
# DATABASE_URL=postgresql://...render-provided-url...

ALLOWED_ORIGINS=http://localhost:3000
# Production: ALLOWED_ORIGINS=https://your-site.onrender.com
